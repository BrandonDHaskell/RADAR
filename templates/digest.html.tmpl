<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>RADAR Digest</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; background: #fafafa; }
  h1 { font-size: 1.5rem; }
  .entry { border: 1px solid #ddd; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1rem; background: #fff; }
  .entry h2 { margin: 0 0 0.5rem; font-size: 1.15rem; }
  .meta { font-size: 0.9rem; color: #555; margin-bottom: 0.5rem; }
  .verdict { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 4px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
  .verdict-pursue { background: #d4f4dd; color: #1a7431; }
  .verdict-stretch { background: #fff3cd; color: #8a6500; }
  .verdict-skip { background: #f1f1f1; color: #666; }
  .reasoning { margin: 0.5rem 0; line-height: 1.4; }
  a.apply { display: inline-block; margin-top: 0.5rem; color: #0a5cc9; text-decoration: none; font-weight: 600; }
  a.apply:hover { text-decoration: underline; }
  .empty { color: #666; }
</style>
</head>
<body>
<h1>RADAR Digest ({{.GeneratedAt}})</h1>
{{if not .Entries}}
<p class="empty">No open, un-applied postings matched your criteria.</p>
{{else}}{{range .Entries}}
<div class="entry">
  <h2>{{.Title}} at {{.Company}}</h2>
  <div class="meta">
    {{if .Verdict}}<span class="verdict verdict-{{.Verdict}}">{{.Verdict}}</span>{{if .MatchedRoleTag}} &middot; {{.MatchedRoleTag}}{{end}}{{end}}
    {{if .Location}}{{if .Verdict}} &middot;{{end}} {{.Location}}{{end}}
    {{if .SalaryRange}} &middot; {{.SalaryRange}}{{end}}
    {{if .SemanticScore}} &middot; semantic {{.SemanticScore}}{{end}}
  </div>
  {{if .Reasoning}}<p class="reasoning">{{.Reasoning}}</p>{{end}}
  <a class="apply" href="{{.ApplyURL}}">Apply &rarr;</a>
</div>
{{end}}{{end}}
</body>
</html>
